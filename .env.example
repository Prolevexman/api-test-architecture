# Copy to ".env" for local runs.
# Precedence: -D... > OS env vars > .env
#
# Keys mapping examples:
# api.baseUri -> API_BASEURI
# api.email   -> API_EMAIL
# api.password-> API_PASSWORD

API_BASEURI=https://your-host.example/
API_EMAIL=your.user@example.com
API_PASSWORD=change-me

# Optional timeouts (ms)
# API_CONNECTTIMEOUTMS=3000
# API_READTIMEOUTMS=10000

