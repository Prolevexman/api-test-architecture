sequenceDiagram
    participant Test as SignInPositiveTest
    participant Ext as WebDriverExtension
    participant DF as DriverFactory
    participant WD as WebDriver
    participant Login as LoginPage
    participant Locator as LocatorResolver
    participant Config as ConfigReader
    participant Users as TestUsers
    participant User as User
    participant Nav as NavigationPanel
    participant Reports as ReportsPage
    participant Assert as Assertions

    Test->>Ext: beforeEach(context)
    Ext->>DF: getDriver()
    DF-->>Ext: WebDriver instance
    Ext-->>Test: inject driver

    Test->>Login: new LoginPage(driver)
    Test->>Login: openLoginPage()
    Login->>Config: get("login.page.url")
    Login->>Login: openPage(URL)
    Login->>Login: waitVisibilityOfElement(loginButton)

    Test->>Users: supplier()
    Users->>EnvCredentialsProvider: getUser("supplier",1)
    EnvCredentialsProvider->>Config: getEnvCredential("supplier","email",1)
    EnvCredentialsProvider->>Config: getEnvCredential("supplier","pass",1)
    EnvCredentialsProvider-->>Users: User(email, pass)
    Users-->>Test: User instance

    Test->>Login: fillUsername(user.getEmail())
    Login->>Login: typeText(usernameField, email)
    Test->>Login: fillPassword(user.getPass())
    Login->>Login: typeText(passwordField, pass)
    Test->>Reports: clickLoginButton()
    Login->>Reports: new ReportsPage(driver)

    Test->>Nav: new NavigationPanel(driver)
    Test->>Assert: assertTrue(navigationPanel.isVisibleLogoutButton())
    Test->>Assert: assertTrue(reportsPage.isLoaded())

    Test->>Ext: afterEach(context)
    Ext->>DF: quitDriver()
